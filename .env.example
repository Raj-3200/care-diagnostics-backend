NODE_ENV=development
PORT=4000
# 15 minutes (in milliseconds)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per IP per window
RATE_LIMIT_MAX=100
DATABASE_URL=postgresql://user:password@host:port/dbname
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-CHANGE-THIS-IN-PRODUCTION
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-CHANGE-THIS-IN-PRODUCTION
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# In production, set to your Vercel frontend URL (e.g. https://care-diagnostics.vercel.app)
# Multiple origins: comma-separated (e.g. https://app.example.com,https://admin.example.com)
CORS_ORIGIN=http://localhost:3000

# AI Assistant (optional — works without it using built-in fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
